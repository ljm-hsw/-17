# Create .env.cos.local beside this file. Never commit real credentials.
COS_SECRET_ID=
COS_SECRET_KEY=
# Optional when using a temporary STS credential.
COS_SESSION_TOKEN=
# Bucket name must include the APPID suffix, for example travelweave-1250000000.
COS_BUCKET=
COS_REGION=ap-chengdu
COS_PREFIX=travelweave
# Keep public-read for direct image URLs, or leave empty when the bucket/CDN policy is already public.
COS_OBJECT_ACL=public-read
# Optional custom CDN domain including COS_PREFIX, for example https://img.example.com/travelweave
COS_PUBLIC_BASE_URL=

<view class="container">
  <view class="header">
    <text class="title">我的江安游迹</text>
  </view>

  <view class="timeline-box">
    <view wx:if="{{routeList.length === 0}}" class="empty">暂无打卡记录，快去刷卡吧！</view>
    <block wx:for="{{routeList}}" wx:key="time">
      <view class="timeline-item">
        <view class="time-dot"></view>
        <view class="time-text">{{item.time}}</view>
        <view class="info-card">
          <text class="spot-name">{{item.spot_name}}</text>
          <text class="uid-text">卡号: {{item.card_uid}}</text>
        </view>
      </view>
    </block>
  </view>
  <button class="refresh-btn" type="primary" bindtap="fetchRouteData">刷新最新路线</button>
</view>
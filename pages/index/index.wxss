.page { min-height: 100vh; background: #F5EFE6; padding-bottom: 120rpx; }
.hero-section { width: 100%; height: 420rpx; position: relative; }
.hero-image { width: 100%; height: 100%; }
.hero-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 40rpx 32rpx 30rpx; background: linear-gradient(transparent, rgba(0,0,0,0.5)); display: flex; flex-direction: column; }
.hero-title { font-size: 40rpx; font-weight: 800; color: #fff; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3); }
.hero-subtitle { font-size: 24rpx; color: rgba(255,255,255,0.85); margin-top: 6rpx; }
.progress-card { margin: -30rpx 24rpx 0; background: #fff; border-radius: 20rpx; padding: 28rpx 28rpx 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); position: relative; z-index: 2; }
.progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.progress-title { font-size: 28rpx; font-weight: 700; color: #222; }
.progress-stat { font-size: 24rpx; color: #2B7A4B; font-weight: 600; }
.progress-bar { height: 16rpx; background: #eee; border-radius: 8rpx; overflow: hidden; margin-bottom: 8rpx; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #2B7A4B, #4CAF50); border-radius: 8rpx; transition: width 0.3s; }
.progress-percent { font-size: 22rpx; color: #888; }
.grid-section { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; padding: 24rpx; }
.grid-item { background: #fff; border-radius: 20rpx; padding: 28rpx 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); display: flex; flex-direction: column; align-items: center; }
.grid-icon-wrap { width: 88rpx; height: 88rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 12rpx; }
.map-bg { background: #E8F5E9; }
.bind-bg { background: #FFF3E0; }
.record-bg { background: #E3F2FD; }
.recall-bg { background: #FCE4EC; }
.grid-icon { font-size: 40rpx; }
.grid-label { font-size: 28rpx; font-weight: 700; color: #222; margin-bottom: 4rpx; }
.grid-desc { font-size: 22rpx; color: #999; text-align: center; }
.recommend-section { padding: 0 24rpx; margin-top: 8rpx; }
.recommend-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.recommend-title { font-size: 32rpx; font-weight: 700; color: #222; }
.recommend-more { font-size: 24rpx; color: #2B4C3F; }
.recommend-swiper { height: 360rpx; border-radius: 20rpx; overflow: hidden; }
.recommend-card { width: 100%; height: 100%; position: relative; border-radius: 20rpx; overflow: hidden; }
.recommend-img { width: 100%; height: 100%; }
.recommend-info { position: absolute; bottom: 0; left: 0; right: 0; padding: 30rpx 24rpx 24rpx; background: linear-gradient(transparent, rgba(0,0,0,0.6)); }
.recommend-name { display: block; font-size: 32rpx; font-weight: 700; color: #fff; text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.3); }
.recommend-tag { display: inline-block; font-size: 20rpx; color: #fff; background: rgba(43,76,63,0.7); padding: 4rpx 16rpx; border-radius: 20rpx; margin-top: 8rpx; }
.bottom-spacer { height: 40rpx; }

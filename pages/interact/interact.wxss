.page{min-height:100vh;background:#F5EFE6;padding:0 24rpx;box-sizing:border-box;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif}
.header{display:flex;justify-content:space-between;align-items:center;padding:24rpx 0}
.map-link{display:flex;align-items:center;gap:8rpx}
.map-icon{font-size:36rpx}
.map-text{font-size:28rpx;color:#2B4C3F;font-weight:600}
.eco-badge{display:flex;align-items:center;gap:8rpx;background:#fff;border-radius:24rpx;padding:8rpx 16rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.06)}
.eco-icon{font-size:28rpx}
.eco-label{font-size:22rpx;color:#666}
.eco-points{font-size:22rpx;color:#2B7A4B;font-weight:700}
.section{margin-top:24rpx}
.section-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12rpx}
.section-title{font-size:32rpx;font-weight:700;color:#222}
.section-sub{font-size:22rpx;color:#888}
.task-card{background:#fff;border-radius:20rpx;padding:24rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.06)}
.task-row{display:flex;align-items:center;gap:12rpx;margin-bottom:16rpx}
.task-icon{font-size:28rpx}
.task-title{font-size:28rpx;font-weight:600;color:#222;flex:1}
.task-loc{font-size:22rpx;color:#888}
.progress-bar{height:16rpx;background:#eee;border-radius:8rpx;overflow:hidden;margin-bottom:8rpx}
.progress-fill{height:100%;background:linear-gradient(90deg,#D4A86A,#E8C78A);border-radius:8rpx}
.progress-num{font-size:22rpx;color:#D4A86A;font-weight:700}
.partner-card{background:#fff;border-radius:20rpx;padding:24rpx;display:flex;align-items:center;gap:20rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.06)}
.partner-avatar{width:96rpx;height:96rpx;border-radius:50%;background:#E8DDD0}
.partner-info{flex:1}
.partner-name{display:block;font-size:30rpx;font-weight:700;color:#222}
.partner-mood{display:block;font-size:24rpx;color:#888;margin-top:4rpx}
.partner-meta{text-align:right}
.meta-label{display:block;font-size:20rpx;color:#aaa}
.meta-value{display:block;font-size:22rpx;color:#666;margin-top:4rpx}
.progress-section{margin-top:16rpx;display:flex;gap:24rpx}
.progress-item{flex:1}
.progress-label{font-size:22rpx;color:#888;margin-bottom:8rpx;display:block}
.bar-track{height:12rpx;background:#eee;border-radius:6rpx;overflow:hidden}
.bar-fill{height:100%;background:#D4A86A;border-radius:6rpx}
.bar-fill.intimacy{background:#E8A0BF}
.quote-box{margin-top:32rpx;padding:24rpx;background:#fff;border-radius:16rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04)}
.quote-text{font-size:24rpx;color:#666;line-height:1.6;text-align:center}

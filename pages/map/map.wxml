<view class="page">
  <view class="search-bar" bindtap="onSearchTap">
    <text class="search-icon">🔍</text>
    <text class="search-placeholder">搜索地点、建筑、景观设施</text>
  </view>

  <scroll-view class="tag-scroll" scroll-x enable-flex>
    <view class="tag-list">
      <view class="tag-item {{activeTag === item.key ? 'active' : ''}}" wx:for="{{tags}}" wx:key="key" bindtap="onTagTap" data-key="{{item.key}}">
        <text>{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="map-area">
    <image class="campus-map" src="/assets/campus-map-comic.jpg" mode="aspectFit" />
    <view class="spot-marker {{item.checked ? 'checked' : ''}}" wx:for="{{spots}}" wx:key="id" style="left: {{item.x}}rpx; top: {{item.y}}rpx;" bindtap="onSpotTap" data-id="{{item.id}}">
      <view class="marker-dot">
        <text class="marker-icon">{{item.checked ? '✓' : '📍'}}</text>
      </view>
      <text class="marker-name">{{item.name}}</text>
    </view>
  </view>

  <view class="float-btns">
    <view class="float-btn" bindtap="onRoutePlan">
      <text class="float-icon">🧭</text>
      <text class="float-label">路线</text>
    </view>
    <view class="float-btn" bindtap="onVoiceGuide">
      <text class="float-icon">🎧</text>
      <text class="float-label">讲解</text>
    </view>
  </view>

  <view class="route-card">
    <view class="route-info">
      <text class="route-title">推荐游览路线（约2.5小时）</text>
      <text class="route-progress">已完成 {{routeChecked}}/{{routeTotal}} 个点位</text>
    </view>
    <button class="route-btn" bindtap="onViewRoute">查看路线</button>
  </view>

  <view class="spot-popup-mask" wx:if="{{showPopup}}" bindtap="closePopup"></view>
  <view class="spot-popup {{showPopup ? 'show' : ''}}">
    <view class="popup-close" bindtap="closePopup"><text>✕</text></view>
    <view class="popup-content" wx:if="{{selectedSpot}}">
      <swiper class="popup-swiper" indicator-dots circular>
        <swiper-item wx:for="{{selectedSpot.images}}" wx:key="*this">
          <image class="popup-img" src="{{item}}" mode="aspectFill" />
        </swiper-item>
      </swiper>
      <view class="popup-header">
        <view class="popup-title-row">
          <text class="popup-name">{{selectedSpot.name}}</text>
          <view class="popup-fav" bindtap="onToggleFav"><text>{{selectedSpot.faved ? '⭐' : '☆'}}</text></view>
        </view>
        <view class="popup-tags">
          <text class="popup-tag" wx:for="{{selectedSpot.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
      </view>
      <text class="popup-desc">{{selectedSpot.description}}</text>
      <view class="popup-info-grid">
        <view class="info-item"><text class="info-label">推荐游览时长</text><text class="info-value">{{selectedSpot.duration}}</text></view>
        <view class="info-item"><text class="info-label">适合的时间段</text><text class="info-value">{{selectedSpot.bestTime}}</text></view>
        <view class="info-item"><text class="info-label">距离当前位置</text><text class="info-value">{{selectedSpot.distance}}</text></view>
        <view class="info-item"><text class="info-label">打卡状态</text><text class="info-value {{selectedSpot.checked ? 'checked-text' : ''}}">{{selectedSpot.checked ? '已打卡' : '未打卡'}}</text></view>
      </view>
      <view class="popup-history" wx:if="{{selectedSpot.history}}">
        <text class="history-title">📖 历史文化</text>
        <text class="history-text">{{selectedSpot.history}}</text>
      </view>
      <view class="popup-actions">
        <button class="action-btn primary" bindtap="onNavigate">前往导览</button>
        <button class="action-btn secondary" bindtap="onCheckin" wx:if="{{!selectedSpot.checked}}">打卡</button>
      </view>
    </view>
  </view>
</view>
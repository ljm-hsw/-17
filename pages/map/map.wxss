.page { min-height: 100vh; background: #F5EFE6; position: relative; }
.search-bar { display: flex; align-items: center; margin: 16rpx 24rpx; padding: 18rpx 24rpx; background: #fff; border-radius: 40rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-placeholder { font-size: 26rpx; color: #bbb; }
.tag-scroll { white-space: nowrap; padding: 0 24rpx; margin-bottom: 12rpx; }
.tag-list { display: inline-flex; gap: 16rpx; padding: 4rpx 0; }
.tag-item { display: inline-flex; padding: 10rpx 28rpx; background: #fff; border-radius: 32rpx; font-size: 24rpx; color: #666; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.tag-item.active { background: #2B4C3F; color: #fff; }
.map-area { position: relative; width: 700rpx; height: 700rpx; margin: 0 auto; border-radius: 20rpx; overflow: hidden; background: #E8F5E9; }
.campus-map { width: 100%; height: 100%; }
.spot-marker { position: absolute; display: flex; flex-direction: column; align-items: center; transform: translate(-50%, -100%); z-index: 5; }
.marker-dot { width: 48rpx; height: 48rpx; border-radius: 50%; background: #E53935; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 12rpx rgba(229,57,53,0.4); border: 3rpx solid #fff; }
.spot-marker.checked .marker-dot { background: #2B7A4B; box-shadow: 0 4rpx 12rpx rgba(43,122,75,0.4); }
.marker-icon { font-size: 22rpx; color: #fff; }
.marker-name { font-size: 18rpx; color: #333; background: rgba(255,255,255,0.9); padding: 2rpx 10rpx; border-radius: 8rpx; margin-top: 4rpx; white-space: nowrap; font-weight: 600; }
.float-btns { position: fixed; right: 24rpx; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 20rpx; z-index: 10; }
.float-btn { width: 96rpx; height: 96rpx; border-radius: 50%; background: #fff; display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12); }
.float-icon { font-size: 32rpx; }
.float-label { font-size: 18rpx; color: #666; margin-top: 2rpx; }
.route-card { position: fixed; bottom: 24rpx; left: 24rpx; right: 24rpx; background: #fff; border-radius: 20rpx; padding: 24rpx; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1); z-index: 10; }
.route-info { flex: 1; }
.route-title { display: block; font-size: 28rpx; font-weight: 700; color: #222; }
.route-progress { display: block; font-size: 22rpx; color: #2B7A4B; margin-top: 6rpx; }
.route-btn { background: #2B4C3F; color: #fff; font-size: 24rpx; padding: 14rpx 32rpx; border-radius: 12rpx; border: none; font-weight: 600; }
.route-btn::after { border: none; }
.spot-popup-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; }
.spot-popup { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; border-radius: 28rpx 28rpx 0 0; max-height: 85vh; overflow-y: auto; z-index: 101; transform: translateY(100%); transition: transform 0.3s ease; }
.spot-popup.show { transform: translateY(0); }
.popup-close { position: absolute; top: 20rpx; right: 24rpx; width: 56rpx; height: 56rpx; border-radius: 50%; background: rgba(0,0,0,0.06); display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #666; z-index: 2; }
.popup-content { padding: 0 0 40rpx; }
.popup-swiper { height: 360rpx; width: 100%; }
.popup-img { width: 100%; height: 100%; }
.popup-header { padding: 24rpx 28rpx 0; }
.popup-title-row { display: flex; justify-content: space-between; align-items: center; }
.popup-name { font-size: 36rpx; font-weight: 800; color: #222; }
.popup-fav { font-size: 36rpx; padding: 8rpx; }
.popup-tags { display: flex; gap: 12rpx; margin-top: 12rpx; flex-wrap: wrap; }
.popup-tag { font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 24rpx; background: #E8F5E9; color: #2B7A4B; }
.popup-desc { display: block; padding: 20rpx 28rpx; font-size: 26rpx; color: #555; line-height: 1.8; }
.popup-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rpx; margin: 0 28rpx; background: #f0f0f0; border-radius: 16rpx; overflow: hidden; }
.info-item { background: #fff; padding: 20rpx 24rpx; }
.info-label { display: block; font-size: 22rpx; color: #999; margin-bottom: 6rpx; }
.info-value { display: block; font-size: 26rpx; font-weight: 600; color: #222; }
.checked-text { color: #2B7A4B; }
.popup-history { margin: 20rpx 28rpx 0; padding: 24rpx; background: #FFF8E1; border-radius: 16rpx; }
.history-title { display: block; font-size: 28rpx; font-weight: 700; color: #222; margin-bottom: 12rpx; }
.history-text { display: block; font-size: 24rpx; color: #666; line-height: 1.8; }
.popup-actions { display: flex; gap: 20rpx; padding: 24rpx 28rpx 0; }
.action-btn { flex: 1; height: 80rpx; border-radius: 16rpx; font-size: 28rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; border: none; }
.action-btn::after { border: none; }
.action-btn.primary { background: #2B4C3F; color: #fff; }
.action-btn.secondary { background: #FFF3E0; color: #E65100; }

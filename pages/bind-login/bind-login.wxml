<view class="page">
  <view class="bg-area">
    <image class="campus-bg" src="/assets/campus-jiangan.jpg" mode="aspectFill" />
    <view class="bg-overlay"></view>
    <view class="brand-area">
      <image class="logo" src="/assets/scu-logo.png" mode="aspectFit" />
      <text class="app-name">游迹织梦</text>
      <text class="app-subtitle">四川大学江安校区智慧景观导览</text>
    </view>
  </view>
  <view class="bind-card">
    <text class="welcome-title">欢迎来到游迹织梦</text>
    <text class="welcome-desc">绑定微信账号后，可保存打卡记录，发现更趣味的 AI 记忆</text>
    <view class="user-preview">
      <image class="user-avatar" src="{{avatarUrl || '/assets/avatar-default.png'}}" mode="aspectFill" />
      <view class="user-meta">
        <text class="user-nickname">{{nickName || '微信用户'}}</text>
        <text class="user-label">微信账号</text>
      </view>
      <view class="check-icon" wx:if="{{nickName}}">
        <text class="check-mark">✓</text>
      </view>
    </view>
    <button class="btn-primary" bindtap="onBindWechat">
      <text class="btn-icon">💬</text>
      <text>微信一键绑定</text>
    </button>
    <button class="btn-secondary" bindtap="onSkip">暂不绑定，先浏览</button>
    <view class="agreement-row" bindtap="toggleAgreement">
      <view class="checkbox {{agreed ? 'checked' : ''}}">
        <text wx:if="{{agreed}}">✓</text>
      </view>
      <text class="agreement-text">我已阅读并同意</text>
      <text class="agreement-link" catchtap="viewAgreement" data-type="user">《用户协议》</text>
      <text class="agreement-text">和</text>
      <text class="agreement-link" catchtap="viewAgreement" data-type="privacy">《隐私政策》</text>
    </view>
  </view>
  <view class="privacy-note">
    <text class="privacy-icon">🛡</text>
    <text class="privacy-text">仅用于您的游览记录，不会公开个人信息</text>
  </view>
</view>
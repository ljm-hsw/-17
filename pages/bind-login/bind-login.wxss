.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8DDD0 0%, #F5EFE6 40%);
  display: flex; flex-direction: column; align-items: center;
}
.bg-area { width: 100%; height: 480rpx; position: relative; overflow: hidden; }
.campus-bg { width: 100%; height: 100%; }
.bg-overlay { position: absolute; bottom: 0; left: 0; right: 0; height: 200rpx; background: linear-gradient(transparent, #E8DDD0); }
.brand-area { position: absolute; top: 80rpx; left: 0; right: 0; display: flex; flex-direction: column; align-items: center; z-index: 2; }
.logo { width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.9); margin-bottom: 16rpx; }
.app-name { font-size: 44rpx; font-weight: 800; color: #2B4C3F; letter-spacing: 4rpx; }
.app-subtitle { font-size: 24rpx; color: #5A7A6A; margin-top: 8rpx; }
.bind-card { width: 660rpx; background: #fff; border-radius: 28rpx; padding: 48rpx 40rpx; margin-top: -40rpx; box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.08); display: flex; flex-direction: column; align-items: center; z-index: 3; }
.welcome-title { font-size: 36rpx; font-weight: 700; color: #222; margin-bottom: 12rpx; }
.welcome-desc { font-size: 24rpx; color: #888; text-align: center; line-height: 1.6; margin-bottom: 32rpx; }
.user-preview { display: flex; align-items: center; width: 100%; padding: 20rpx 24rpx; background: #F8F6F2; border-radius: 16rpx; margin-bottom: 32rpx; }
.user-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; border: 3rpx solid #E8DDD0; }
.user-meta { flex: 1; margin-left: 20rpx; }
.user-nickname { display: block; font-size: 28rpx; font-weight: 600; color: #222; }
.user-label { display: block; font-size: 22rpx; color: #aaa; margin-top: 4rpx; }
.check-icon { width: 48rpx; height: 48rpx; border-radius: 50%; background: #2B7A4B; display: flex; align-items: center; justify-content: center; }
.check-mark { color: #fff; font-size: 28rpx; font-weight: 700; }
.btn-primary { width: 100%; height: 88rpx; background: #2B4C3F; color: #fff; font-size: 30rpx; font-weight: 600; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; gap: 12rpx; border: none; margin-bottom: 20rpx; }
.btn-primary::after { border: none; }
.btn-icon { font-size: 32rpx; }
.btn-secondary { width: 100%; height: 88rpx; background: transparent; color: #666; font-size: 28rpx; border-radius: 16rpx; border: 2rpx solid #ddd; display: flex; align-items: center; justify-content: center; }
.btn-secondary::after { border: none; }
.agreement-row { display: flex; align-items: center; margin-top: 24rpx; flex-wrap: wrap; justify-content: center; }
.checkbox { width: 32rpx; height: 32rpx; border: 2rpx solid #ccc; border-radius: 6rpx; display: flex; align-items: center; justify-content: center; margin-right: 8rpx; font-size: 22rpx; color: #fff; }
.checkbox.checked { background: #2B7A4B; border-color: #2B7A4B; }
.agreement-text { font-size: 22rpx; color: #999; }
.agreement-link { font-size: 22rpx; color: #2B4C3F; text-decoration: underline; }
.privacy-note { display: flex; align-items: center; gap: 8rpx; margin-top: 40rpx; padding-bottom: 60rpx; }
.privacy-icon { font-size: 28rpx; }
.privacy-text { font-size: 22rpx; color: #999; }

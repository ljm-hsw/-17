.page{min-height:100vh;background:#F5EFE6;padding:0 24rpx 160rpx;box-sizing:border-box}
.header{padding:24rpx 0}
.user-row{display:flex;align-items:center;gap:16rpx}
.avatar{width:80rpx;height:80rpx;border-radius:50%;background:#E8DDD0}
.user-meta{display:flex;flex-direction:column}
.nickname{font-size:28rpx;font-weight:700;color:#222}
.date-text{font-size:22rpx;color:#888;margin-top:4rpx}
.post-card{background:#fff;border-radius:20rpx;padding:24rpx;margin-top:20rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.06)}
.post-title{font-size:28rpx;font-weight:600;color:#222;line-height:1.5;margin-bottom:16rpx}
.post-image{width:100%;height:360rpx;border-radius:12rpx;object-fit:cover;margin-bottom:16rpx}
.post-actions{display:flex;gap:48rpx;padding-top:8rpx}
.action-item{display:flex;align-items:center;gap:8rpx}
.heart-icon{font-size:32rpx;color:#E85D75}
.comment-icon{font-size:28rpx}
.share-icon{font-size:28rpx}
.action-num{font-size:24rpx;color:#888}
.fab{position:fixed;right:32rpx;bottom:180rpx;width:100rpx;height:100rpx;border-radius:50%;background:#2B4C3F;display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 24rpx rgba(43,76,63,.25);z-index:99}
.fab-plus{font-size:48rpx;color:#fff;line-height:1}
.tab-bar{position:fixed;bottom:0;left:0;right:0;height:120rpx;background:#fff;display:flex;justify-content:space-around;align-items:center;border-top:1rpx solid #eee;padding-bottom:env(safe-area-inset-bottom)}
.tab-item{display:flex;flex-direction:column;align-items:center;gap:4rpx}
.tab-icon{font-size:36rpx}
.tab-label{font-size:20rpx;color:#999}
.tab-item.active .tab-label{color:#2B4C3F;font-weight:700}

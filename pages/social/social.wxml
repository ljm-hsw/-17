<view class="page">
  <!-- Header -->
  <view class="header">
    <view class="user-row">
      <image class="avatar" src="/assets/avatar-default.png" mode="aspectFill" />
      <view class="user-meta">
        <text class="nickname">Wink</text>
        <text class="date-text">12小雨</text>
      </view>
    </view>
  </view>

  <!-- Post Card -->
  <view class="post-card" wx:for="{{posts}}" wx:key="id" bindtap="onPostTap" data-id="{{item.id}}">
    <text class="post-title">{{item.title}}</text>
    <image class="post-image" src="{{item.cover}}" mode="aspectFill" />
    <view class="post-actions">
      <view class="action-item"><text class="heart-icon">♡</text><text class="action-num">{{item.likes}}</text></view>
      <view class="action-item"><text class="comment-icon">💬</text><text class="action-num">{{item.comments}}</text></view>
      <view class="action-item"><text class="share-icon">↗</text><text class="action-num">{{item.shares}}</text></view>
    </view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="onPublish">
    <text class="fab-plus">+</text>
  </view>

  <!-- Tab Bar -->
  <view class="tab-bar">
    <view class="tab-item" bindtap="()=>wx.switchTab({url:'/pages/index/index'})">
      <text class="tab-icon">💬</text>
      <text class="tab-label">首页</text>
    </view>
    <view class="tab-item active">
      <text class="tab-icon">👥</text>
      <text class="tab-label">AI智能体</text>
    </view>
    <view class="tab-item" bindtap="()=>wx.switchTab({url:'/pages/mine/mine'})">
      <text class="tab-icon">👤</text>
      <text class="tab-label">我的</text>
    </view>
  </view>
</view>

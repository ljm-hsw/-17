.page{min-height:100vh;background:#F5EFE6;padding:0 24rpx;box-sizing:border-box}
.header{display:flex;justify-content:space-between;align-items:center;padding:24rpx 0}
.page-title{font-size:32rpx;font-weight:700;color:#222}
.settings-btn{width:48rpx;height:48rpx;display:flex;align-items:center;justify-content:center}
.settings-icon{font-size:32rpx;color:#666}
.profile-card{display:flex;align-items:center;gap:20rpx;padding:24rpx;background:#fff;border-radius:20rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.06)}
.avatar{width:96rpx;height:96rpx;border-radius:50%;background:#E8DDD0}
.profile-info{flex:1}
.nickname{display:block;font-size:32rpx;font-weight:700;color:#222}
.tags{display:flex;gap:12rpx;margin-top:8rpx}
.tag{font-size:20rpx;padding:4rpx 12rpx;border-radius:20rpx;background:#f0ebe3;color:#2B4C3F}
.stats-row{display:flex;justify-content:space-around;background:#fff;border-radius:20rpx;padding:24rpx 0;margin-top:20rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.06)}
.stat-item{display:flex;flex-direction:column;align-items:center}
.stat-value{font-size:32rpx;font-weight:700;color:#2B4C3F}
.stat-label{font-size:22rpx;color:#888;margin-top:4rpx}
.menu-list{margin-top:20rpx;background:#fff;border-radius:20rpx;overflow:hidden;box-shadow:0 4rpx 16rpx rgba(0,0,0,.06)}
.menu-item{display:flex;justify-content:space-between;align-items:center;padding:28rpx 24rpx;border-bottom:1rpx solid #f0ebe3}
.menu-item:last-child{border-bottom:none}
.menu-title{font-size:28rpx;color:#222}
.menu-arrow{font-size:32rpx;color:#ccc}
